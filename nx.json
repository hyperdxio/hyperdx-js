{
  "workspaceLayout": {
    "appsDir": "packages",
    "libsDir": "packages"
  },
  "targetDefaults": {
    "prebuild": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "^postbuild", "prebuild"],
      "outputs": ["{projectRoot}/build", "{projectRoot}/dist"],
      "cache": true
    },
    "postbuild": {
      "dependsOn": ["build"],
      "outputs": ["{projectRoot}/build", "{projectRoot}/dist"],
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "test": {
      "cache": true
    }
  },
  "useInferencePlugins": false,
  "defaultBase": "main"
}
